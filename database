-- Create Database
CREATE DATABASE users_api;

-- Use Database
\c login_api;

-- Create Table
CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    users VARCHAR(100) NOT NULL,
    email VARCHAR(150) UNIQUE NOT NULL,
    mobile VARCHAR(15) UNIQUE NOT NULL,
    pass VARCHAR(255) NOT NULL
);

